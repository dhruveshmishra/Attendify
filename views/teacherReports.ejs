<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teacher Reports | Attendify</title>

    <link rel="stylesheet" href="/css/teacherDashboard.css">

    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    >
</head>
<body>

<div class="teacher-page">

    <aside class="teacher-sidebar">
        <div class="teacher-brand">
            <i class="fa-solid fa-clipboard-check"></i>
            <span>Attendify</span>
        </div>

        <nav class="teacher-nav">
            <a href="/teacher/dashboard">
                <i class="fa-solid fa-gauge"></i>
                Dashboard
            </a>

            <a href="/teacher/reports" class="active">
                <i class="fa-solid fa-chart-column"></i>
                Reports
            </a>

            <a href="/logout">
                <i class="fa-solid fa-right-from-bracket"></i>
                Logout
            </a>
        </nav>
    </aside>

    <main class="teacher-main">

        <header class="teacher-header">
            <div>
                <span class="teacher-kicker">Teacher Panel</span>
                <h1>Attendance Reports</h1>
                <p>View your class-wise, subject-wise and student-wise attendance records.</p>
            </div>
        </header>

        <section class="teacher-card teacher-report-filter-card">
            <div class="teacher-card-header">
                <div>
                    <h3>Filter Reports</h3>
                    <p>Select date range, class group, subject or status.</p>
                </div>
            </div>

            <form action="/teacher/reports" method="GET" class="teacher-report-filter-grid">

                <div class="teacher-field">
                    <label>From Date</label>
                    <input type="date" name="fromDate" value="<%= filters.fromDate %>" required>
                </div>

                <div class="teacher-field">
                    <label>To Date</label>
                    <input type="date" name="toDate" value="<%= filters.toDate %>" required>
                </div>

                <div class="teacher-field">
                    <label>Class Group</label>
                    <select name="classGroupId">
                        <option value="all">All Class Groups</option>

                        <% classGroups.forEach(function(group) { %>
                            <option
                                value="<%= group._id %>"
                                <%= filters.classGroupId === group._id.toString() ? "selected" : "" %>
                            >
                                <%= group.name %> - Sem <%= group.semester %> <%= group.section %>
                            </option>
                        <% }) %>
                    </select>
                </div>

                <div class="teacher-field">
                    <label>Subject</label>
                    <select name="subjectId">
                        <option value="all">All Subjects</option>

                        <% subjects.forEach(function(subject) { %>
                            <option
                                value="<%= subject._id %>"
                                <%= filters.subjectId === subject._id.toString() ? "selected" : "" %>
                            >
                                <%= subject.subjectName %>
                                <% if (subject.subjectCode) { %>
                                    - <%= subject.subjectCode %>
                                <% } %>
                            </option>
                        <% }) %>
                    </select>
                </div>

                <div class="teacher-field">
                    <label>Status</label>
                    <select name="status">
                        <option value="all" <%= filters.status === "all" ? "selected" : "" %>>All</option>
                        <option value="PRESENT" <%= filters.status === "PRESENT" ? "selected" : "" %>>Present</option>
                        <option value="ABSENT" <%= filters.status === "ABSENT" ? "selected" : "" %>>Absent</option>
                    </select>
                </div>

                <div class="teacher-field teacher-button-field">
                    <label>&nbsp;</label>
                    <button class="teacher-primary-btn" type="submit">
                        <i class="fa-solid fa-filter"></i>
                        Apply Filters
                    </button>
                </div>

                <div class="teacher-field teacher-button-field">
                    <label>&nbsp;</label>
                    <a href="/teacher/reports" class="teacher-secondary-btn">
                        <i class="fa-solid fa-rotate-left"></i>
                        Reset
                    </a>
                </div>

            </form>
        </section>

        <section class="teacher-report-summary-grid">

            <article class="teacher-report-stat blue">
                <div>
                    <span>Sessions</span>
                    <strong><%= summary.totalSessions %></strong>
                </div>
                <i class="fa-solid fa-calendar-check"></i>
            </article>

            <article class="teacher-report-stat green">
                <div>
                    <span>Present</span>
                    <strong><%= summary.totalPresent %></strong>
                </div>
                <i class="fa-solid fa-user-check"></i>
            </article>

            <article class="teacher-report-stat red">
                <div>
                    <span>Absent</span>
                    <strong><%= summary.totalAbsent %></strong>
                </div>
                <i class="fa-solid fa-user-xmark"></i>
            </article>

            <article class="teacher-report-stat purple">
                <div>
                    <span>Attendance</span>
                    <strong><%= summary.attendancePercentage %>%</strong>
                </div>
                <i class="fa-solid fa-chart-line"></i>
            </article>

            <article class="teacher-report-stat orange">
                <div>
                    <span>Suspicious</span>
                    <strong><%= summary.suspiciousCount %></strong>
                </div>
                <i class="fa-solid fa-triangle-exclamation"></i>
            </article>

        </section>

        <section class="teacher-card">
            <div class="teacher-card-header">
                <div>
                    <h3>Subject-wise Summary</h3>
                    <p>Attendance grouped by your subjects.</p>
                </div>
            </div>

            <% if (!subjectSummary || subjectSummary.length === 0) { %>
                <div class="teacher-empty">No subject report found.</div>
            <% } else { %>
                <div class="teacher-table-wrap">
                    <table class="teacher-report-table">
                        <thead>
                            <tr>
                                <th>Subject</th>
                                <th>Code</th>
                                <th>Total</th>
                                <th>Present</th>
                                <th>Absent</th>
                                <th>Attendance</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% subjectSummary.forEach(function(item) { %>
                                <tr>
                                    <td><strong><%= item.name %></strong></td>
                                    <td><%= item.code || "-" %></td>
                                    <td><%= item.total %></td>
                                    <td class="teacher-success"><%= item.present %></td>
                                    <td class="teacher-danger"><%= item.absent %></td>
                                    <td>
                                        <span class="teacher-percent-pill <%= item.percentage >= 75 ? 'good' : 'bad' %>">
                                            <%= item.percentage %>%
                                        </span>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </section>

        <section class="teacher-card">
            <div class="teacher-card-header">
                <div>
                    <h3>Class-wise Summary</h3>
                    <p>Attendance grouped by class groups.</p>
                </div>
            </div>

            <% if (!classSummary || classSummary.length === 0) { %>
                <div class="teacher-empty">No class report found.</div>
            <% } else { %>
                <div class="teacher-table-wrap">
                    <table class="teacher-report-table">
                        <thead>
                            <tr>
                                <th>Class Group</th>
                                <th>Total</th>
                                <th>Present</th>
                                <th>Absent</th>
                                <th>Attendance</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% classSummary.forEach(function(item) { %>
                                <tr>
                                    <td><strong><%= item.name %></strong></td>
                                    <td><%= item.total %></td>
                                    <td class="teacher-success"><%= item.present %></td>
                                    <td class="teacher-danger"><%= item.absent %></td>
                                    <td>
                                        <span class="teacher-percent-pill <%= item.percentage >= 75 ? 'good' : 'bad' %>">
                                            <%= item.percentage %>%
                                        </span>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </section>

        <section class="teacher-card">
            <div class="teacher-card-header">
                <div>
                    <h3>Student-wise Summary</h3>
                    <p>Attendance grouped by students.</p>
                </div>
            </div>

            <% if (!studentSummary || studentSummary.length === 0) { %>
                <div class="teacher-empty">No student report found.</div>
            <% } else { %>
                <div class="teacher-table-wrap">
                    <table class="teacher-report-table">
                        <thead>
                            <tr>
                                <th>Student</th>
                                <th>Enrollment</th>
                                <th>Total</th>
                                <th>Present</th>
                                <th>Absent</th>
                                <th>Attendance</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% studentSummary.forEach(function(item) { %>
                                <tr>
                                    <td><strong><%= item.name %></strong></td>
                                    <td><%= item.enrollmentNumber || "-" %></td>
                                    <td><%= item.total %></td>
                                    <td class="teacher-success"><%= item.present %></td>
                                    <td class="teacher-danger"><%= item.absent %></td>
                                    <td>
                                        <span class="teacher-percent-pill <%= item.percentage >= 75 ? 'good' : 'bad' %>">
                                            <%= item.percentage %>%
                                        </span>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </section>

        <section class="teacher-card">
            <div class="teacher-card-header">
                <div>
                    <h3>Detailed Attendance Records</h3>
                    <p>Latest 1000 records matching your selected filters.</p>
                </div>

                <span class="teacher-count-pill">
                    <%= attendanceRecords.length %> Records
                </span>
            </div>

            <% if (!attendanceRecords || attendanceRecords.length === 0) { %>
                <div class="teacher-empty">No attendance records found.</div>
            <% } else { %>
                <div class="teacher-table-wrap">
                    <table class="teacher-report-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Student</th>
                                <th>Subject</th>
                                <th>Class</th>
                                <th>Status</th>
                                <th>Method</th>
                                <th>Distance</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% attendanceRecords.forEach(function(record) { %>
                                <%
                                    const session = record.attendanceSession;
                                    const sessionDate = session && session.startTime ? session.startTime : record.createdAt;
                                %>

                                <tr>
                                    <td>
                                        <%= new Date(sessionDate).toLocaleDateString() %>
                                        <br>
                                        <small><%= new Date(sessionDate).toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" }) %></small>
                                    </td>

                                    <td>
                                        <strong><%= record.student ? record.student.fullName : "Student Missing" %></strong>
                                        <br>
                                        <small><%= record.student && record.student.enrollmentNumber ? record.student.enrollmentNumber : "-" %></small>
                                    </td>

                                    <td><%= record.subject ? record.subject.subjectName : "Subject Missing" %></td>

                                    <td><%= record.classGroup ? record.classGroup.name : "Class Missing" %></td>

                                    <td>
                                        <span class="teacher-status <%= record.status === 'PRESENT' ? 'present' : 'absent' %>">
                                            <%= record.status %>
                                        </span>
                                    </td>

                                    <td><%= record.verificationMethod || "-" %></td>

                                    <td>
                                        <% if (record.distanceFromClassroom !== undefined && record.distanceFromClassroom !== null) { %>
                                            <%= Math.round(record.distanceFromClassroom) %>m
                                        <% } else { %>
                                            -
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </section>

        <section class="teacher-card">
            <div class="teacher-card-header">
                <div>
                    <h3>Suspicious Attempts</h3>
                    <p>Rejected attendance attempts for your sessions.</p>
                </div>

                <span class="teacher-count-pill danger">
                    <%= suspiciousAttempts.length %> Attempts
                </span>
            </div>

            <% if (!suspiciousAttempts || suspiciousAttempts.length === 0) { %>
                <div class="teacher-empty">No suspicious attempts found.</div>
            <% } else { %>
                <div class="teacher-table-wrap">
                    <table class="teacher-report-table">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Student</th>
                                <th>Reason</th>
                                <th>Distance</th>
                                <th>Radius</th>
                                <th>Accuracy</th>
                            </tr>
                        </thead>

                        <tbody>
                            <% suspiciousAttempts.forEach(function(attempt) { %>
                                <tr>
                                    <td>
                                        <%= new Date(attempt.createdAt).toLocaleDateString() %>
                                        <br>
                                        <small><%= new Date(attempt.createdAt).toLocaleTimeString([], { hour: "2-digit", minute: "2-digit" }) %></small>
                                    </td>

                                    <td>
                                        <strong><%= attempt.studentName %></strong>
                                        <br>
                                        <small><%= attempt.enrollmentNumber %></small>
                                    </td>

                                    <td>
                                        <strong><%= attempt.reasonCode %></strong>
                                        <br>
                                        <small><%= attempt.reasonMessage %></small>
                                    </td>

                                    <td><%= Math.round(attempt.distanceFromTeacher || 0) %>m</td>
                                    <td><%= Math.round(attempt.allowedRadius || 0) %>m</td>
                                    <td><%= Math.round(attempt.gpsAccuracy || 0) %>m</td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </section>

    </main>

</div>

</body>
</html>